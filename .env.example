# Porta em que o servidor vai rodar / Port the server will run on
PORT=3000

# Chave secreta para assinar os tokens JWT / Secret key to sign JWT tokens
JWT_KEY=sua_chave_secreta_muito_segura_aqui

# Origem permitida para CORS (URL do frontend) / Allowed CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Credenciais do usuário admin inicial / Initial admin user credentials
# Este usuário é criado automaticamente ao iniciar o servidor.
# This user is created automatically when the server starts.
NAME_USER_ADMIN=admin
EMAIL_USER_ADMIN=admin@example.com
PASSWORD_USER_ADMIN=senhaSegura123
